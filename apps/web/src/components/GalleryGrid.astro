---
import 'photoswipe/style.css'
import { hasImage, imageDimensions, sanityImageUrl } from '@lib/sanityImage'
import type { Photo } from '@lib/types'

type Props = {
  photos: Photo[]
}

const { photos } = Astro.props
const galleryId = `gallery-${Math.random().toString(36).slice(2)}`
---

{
  photos.length ? (
    <div class="gallery-grid" id={galleryId}>
      {photos.map((photo) => {
        const dimensions = imageDimensions(photo.image)
        const fullSrc = hasImage(photo.image)
          ? sanityImageUrl(photo.image).width(2400).auto('format').url()
          : ''
        const thumbSrc = hasImage(photo.image)
          ? sanityImageUrl(photo.image).width(700).height(700).fit('crop').auto('format').url()
          : ''
        const alt = photo.image?.alt || photo.title || 'Photo'

        return (
          <a
            href={fullSrc || '#'}
            data-pswp-width={dimensions.width}
            data-pswp-height={dimensions.height}
            aria-label={photo.title || 'Open photo'}
          >
            {thumbSrc ? <img src={thumbSrc} alt={alt} loading="lazy" decoding="async" /> : <span />}
          </a>
        )
      })}
    </div>
  ) : (
    <div class="empty">
      <p>No photos published yet.</p>
    </div>
  )
}

<script define:vars={{ galleryId }}>
  import PhotoSwipeLightbox from 'photoswipe/lightbox'

  const element = document.getElementById(galleryId)

  if (element) {
    const lightbox = new PhotoSwipeLightbox({
      gallery: `#${galleryId}`,
      children: 'a',
      pswpModule: () => import('photoswipe'),
    })

    lightbox.init()
  }
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 4px;
  }

  a {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 4px;
    background: var(--bg-soft);
  }

  img,
  span {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  span {
    display: block;
    background: #20231f;
  }
</style>
