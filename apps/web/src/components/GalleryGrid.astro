---
import 'photoswipe/style.css'
import { hasImage, imageDimensions, sanityImageUrl } from '@lib/sanityImage'
import type { Photo } from '@lib/types'

type Props = {
  photos: Photo[]
}

const { photos } = Astro.props
---

{
  photos.length ? (
    <div class="gallery-grid">
      {photos.map((photo) => {
        const dimensions = imageDimensions(photo.image)
        const fullSrc = hasImage(photo.image)
          ? sanityImageUrl(photo.image).ignoreImageParams().width(2400).auto('format').url()
          : ''
        const thumbSrc = hasImage(photo.image)
          ? sanityImageUrl(photo.image).ignoreImageParams().width(700).auto('format').url()
          : ''
        const alt = photo.image?.alt || photo.title || 'Photo'

        return (
          <a
            href={fullSrc || '#'}
            data-pswp-width={dimensions.width}
            data-pswp-height={dimensions.height}
            aria-label={photo.title || 'Open photo'}
          >
            {thumbSrc ? (
              <img
                src={thumbSrc}
                alt={alt}
                width={dimensions.width}
                height={dimensions.height}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span />
            )}
          </a>
        )
      })}
    </div>
  ) : (
    <div class="empty">
      <p>No photos published yet.</p>
    </div>
  )
}

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox'

  document.querySelectorAll('.gallery-grid').forEach((gallery) => {
    const lightbox = new PhotoSwipeLightbox({
      gallery,
      children: 'a',
      pswpModule: () => import('photoswipe'),
    })

    lightbox.init()
  })
</script>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 4px;
  }

  a {
    display: block;
    border-radius: 4px;
    background: var(--bg-soft);
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: inherit;
  }

  span {
    display: block;
    aspect-ratio: 4 / 3;
    background: #20231f;
  }
</style>
