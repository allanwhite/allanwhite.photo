---
import GalleryGrid from '@components/GalleryGrid.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { renderPortableText } from '@lib/portableText'
import {
  allGearSlugsQuery,
  gearBySlugQuery,
  photosByGearQuery,
  siteSettingsQuery,
} from '@lib/queries'
import { fetchSanity, hasSanityConfig } from '@lib/sanity'
import { hasImage, sanityImageUrl } from '@lib/sanityImage'
import type { Gear, Photo, SiteSettings } from '@lib/types'

export async function getStaticPaths() {
  if (!hasSanityConfig) return []

  const slugs = await fetchSanity<{ slug: string }[]>(allGearSlugsQuery, {}, [])
  return slugs.map(({ slug }) => ({ params: { slug } }))
}

const { slug } = Astro.params
const [settings, gear] = await Promise.all([
  fetchSanity<SiteSettings | null>(siteSettingsQuery, {}, null),
  fetchSanity<Gear | null>(gearBySlugQuery, { slug }, null),
])

if (!gear) return Astro.redirect('/404')

const photos = await fetchSanity<Photo[]>(photosByGearQuery, { gearId: gear._id }, [])
const specsHtml = renderPortableText(gear.specs)
const reviewHtml = renderPortableText(gear.myReview)
const heroSrc = hasImage(gear.heroImage?.image)
  ? sanityImageUrl(gear.heroImage.image).width(1800).height(1000).fit('crop').auto('format').url()
  : ''
---

<BaseLayout title={gear.name} settings={settings}>
  <article>
    <section class="gear-hero">
      {heroSrc && <img src={heroSrc} alt={gear.heroImage?.image?.alt || gear.name || ''} decoding="async" />}
      <div>
        <p class="eyebrow">{gear.manufacturer || 'Gear'}</p>
        <h1>{gear.name}</h1>
        <p class="lede">{gear.type}{gear.rating ? `, rated ${gear.rating}/10` : ''}</p>
        <div class="gear-actions">
          {gear.purchaseUrl && <a class="button" href={gear.purchaseUrl}>Buy</a>}
          {gear.affiliateUrl && <a class="button secondary" href={gear.affiliateUrl}>Affiliate link</a>}
        </div>
      </div>
    </section>
    {
      gear.hasAffiliateLinks && settings?.affiliateDisclosure && (
        <section class="section-narrow disclosure">
          <p>{settings.affiliateDisclosure}</p>
        </section>
      )
    }
    <section class="section-narrow gear-copy">
      {specsHtml && <div class="rich-text" set:html={specsHtml} />}
      {reviewHtml && <div class="rich-text" set:html={reviewHtml} />}
    </section>
    <section class="section">
      <p class="eyebrow">Made with this</p>
      <h2>Photos</h2>
      <GalleryGrid photos={photos} />
    </section>
  </article>
</BaseLayout>

<style>
  .gear-hero {
    position: relative;
    display: grid;
    min-height: 68vh;
    align-items: end;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(210, 168, 93, 0.2), transparent 34%),
      #171a18;
  }

  .gear-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.76;
  }

  .gear-hero::after {
    position: absolute;
    inset: 0;
    content: '';
    background: linear-gradient(90deg, rgba(16, 18, 17, 0.9), rgba(16, 18, 17, 0.22));
  }

  .gear-hero > div {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, var(--max));
    margin: 0 auto;
    padding: 5rem 0;
  }

  .gear-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .disclosure {
    padding-bottom: 0;
  }

  .disclosure p {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1rem;
  }

  .gear-copy {
    display: grid;
    gap: 2rem;
  }
</style>
