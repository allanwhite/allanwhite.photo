---
import PhotoCard from '@components/PhotoCard.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { gearListQuery, siteSettingsQuery } from '@lib/queries'
import { fetchSanity } from '@lib/sanity'
import type { Gear, SiteSettings } from '@lib/types'

const [settings, gear] = await Promise.all([
  fetchSanity<SiteSettings | null>(siteSettingsQuery, {}, null),
  fetchSanity<Gear[]>(gearListQuery, {}, []),
])
---

<BaseLayout title="Gear" settings={settings}>
  <section class="section">
    <p class="eyebrow">Gear</p>
    <h1>Kit notes</h1>
    {
      gear.length ? (
        <div class="gear-grid">
          {gear.map((item) => (
            <article>
              {item.heroImage && <PhotoCard photo={{ ...item.heroImage, title: item.name, slug: item.slug }} />}
              <div>
                <p>{item.manufacturer}</p>
                <h2><a href={item.slug?.current ? `/gear/${item.slug.current}` : '#'}>{item.name}</a></h2>
                <span class="tag-pill">{item.type}</span>
                {item.rating && <strong>{item.rating}/10</strong>}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty">
          <p>No gear notes published yet.</p>
        </div>
      )
    }
  </section>
</BaseLayout>

<style>
  .gear-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  article {
    display: grid;
    gap: 0.85rem;
  }

  h2 {
    margin-bottom: 0.6rem;
    font-size: 1.35rem;
  }

  h2 a {
    text-decoration: none;
  }

  strong {
    display: inline-flex;
    margin-left: 0.5rem;
    color: var(--accent);
  }
</style>
