---
import ExifBlock from '@components/ExifBlock.astro'
import MapEmbed from '@components/MapEmbed.astro'
import TagList from '@components/TagList.astro'
import VideoPlayer from '@components/VideoPlayer.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import { formatDate } from '@lib/format'
import { renderPortableText } from '@lib/portableText'
import { allPhotoSlugsQuery, photoBySlugQuery, siteSettingsQuery } from '@lib/queries'
import { fetchSanity, hasSanityConfig } from '@lib/sanity'
import { hasImage, sanityImageUrl } from '@lib/sanityImage'
import type { Photo, SiteSettings } from '@lib/types'

export async function getStaticPaths() {
  if (!hasSanityConfig) return []

  const slugs = await fetchSanity<{ slug: string }[]>(allPhotoSlugsQuery, {}, [])
  return slugs.map(({ slug }) => ({ params: { slug } }))
}

const { slug } = Astro.params
const [settings, photo] = await Promise.all([
  fetchSanity<SiteSettings | null>(siteSettingsQuery, {}, null),
  fetchSanity<Photo | null>(photoBySlugQuery, { slug }, null),
])

if (!photo) return Astro.redirect('/404')

const imageSrc = hasImage(photo.image)
  ? sanityImageUrl(photo.image).width(2200).auto('format').url()
  : ''
const posterSrc = hasImage(photo.image)
  ? sanityImageUrl(photo.image).width(1000).height(650).fit('crop').auto('format').url()
  : ''
const captionHtml = renderPortableText(photo.captionBody)
---

<BaseLayout title={photo.title} settings={settings}>
  <article class="photo-page">
    <section class="photo-stage">
      {
        imageSrc ? (
          <img src={imageSrc} alt={photo.image?.alt || photo.title || ''} decoding="async" />
        ) : (
          <div class="photo-missing" />
        )
      }
    </section>
    <section class="section photo-details">
      <div>
        <p class="eyebrow">{photo.takenAt ? formatDate(photo.takenAt) : 'Photo'}</p>
        <h1>{photo.title || 'Untitled photo'}</h1>
        {captionHtml && <div class="rich-text" set:html={captionHtml} />}
        <TagList tags={photo.tags} />
      </div>
      <div class="sidebar">
        <ExifBlock photo={photo} />
        <MapEmbed lat={photo.gps?.lat} lng={photo.gps?.lng} />
        <VideoPlayer video={photo.companion?.video} poster={posterSrc} />
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .photo-stage {
    background: #070807;
  }

  .photo-stage img,
  .photo-missing {
    width: 100%;
    max-height: 86vh;
    object-fit: contain;
  }

  .photo-missing {
    min-height: 70vh;
    background:
      linear-gradient(135deg, rgba(210, 168, 93, 0.18), transparent 34%),
      #171a18;
  }

  .photo-details {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.36fr);
    gap: 2rem;
    align-items: start;
  }

  .photo-details h1 {
    max-width: 14ch;
  }

  .sidebar {
    display: grid;
    gap: 1.25rem;
  }

  @media (max-width: 860px) {
    .photo-details {
      grid-template-columns: 1fr;
    }
  }
</style>
